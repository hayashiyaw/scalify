DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scalify?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"

# S3-compatible object storage (local MinIO: `docker compose up -d` — see README)
S3_ENDPOINT="http://127.0.0.1:9000"
S3_REGION="us-east-1"
S3_BUCKET="scalify"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"
# Public URL prefix for avatar objects (path-style: include bucket path, e.g. …/scalify)
S3_PUBLIC_URL_BASE="http://127.0.0.1:9000/scalify"
# Required for MinIO; omit or "false" for default AWS virtual-hosted-style
S3_FORCE_PATH_STYLE="true"
